{
  "name": "sprintdeck",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n WEB,API -c cyan,magenta \"vite\" \"npm --prefix api start -- --port 7072\"",
    "dev:lan": "concurrently -k -n WEB,API -c cyan,magenta \"vite --host\" \"npm --prefix api start -- --port 7072\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
